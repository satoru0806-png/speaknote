// SpeakNote Memo API - 時計からメモを保存・取得
const memos = []; // メモリ内ストレージ（シンプル版）

export default function handler(req, res) {
  // CORS
  res.setHeader('Access-Control-Allow-Origin', '*');
  res.setHeader('Access-Control-Allow-Methods', 'GET, POST, OPTIONS');
  res.setHeader('Access-Control-Allow-Headers', 'Content-Type, x-api-key');

  if (req.method === 'OPTIONS') {
    return res.status(200).end();
  }

  if (req.method === 'POST') {
    const { text, date } = req.body;
    if (!text) return res.status(400).json({ error: 'text required' });

    const memo = {
      id: Date.now().toString(),
      text,
      date: date || new Date().toLocaleString('ja-JP', { timeZone: 'Asia/Tokyo' }),
      createdAt: new Date().toISOString()
    };

    // Vercel Serverless は stateless なので、
    // 実際の永続化は Supabase を使う
    return res.status(200).json({ ok: true, memo });
  }

  return res.status(405).json({ error: 'Method not allowed' });
}
